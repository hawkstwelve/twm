# Copy to: /etc/twf-v3/api.env
TWF_V3_DATA_ROOT=/opt/twf_v3/data/v3

# Loop WebP serving/generation cache
TWF_V3_LOOP_CACHE_ROOT=/opt/twf_v3/data/v3/loop_cache

# Emitted loop URL prefix used by /frames and /loop-manifest.
# Default static route (recommended): /loop/v3
# Dynamic API route option: /api/v4
TWF_V3_LOOP_URL_PREFIX=/loop/v3

# Tier 0 defaults (also used by legacy /loop.webp path)
TWF_V3_LOOP_WEBP_QUALITY=82
TWF_V3_LOOP_WEBP_MAX_DIM=1600

# Tier 1 (high-res) loop settings
TWF_V3_LOOP_WEBP_TIER1_QUALITY=86
TWF_V3_LOOP_WEBP_TIER1_MAX_DIM=2400

# TWF OAuth and REST API settings
TWF_BASE=https://theweatherforums.com
TWF_CLIENT_ID=your_client_id_here
TWF_CLIENT_SECRET=your_client_secret_here
TWF_REDIRECT_URI=https://api.theweathermodels.com/auth/twf/callback
TWF_SCOPES="profile forums_posts"   # use your actual scope keys
FRONTEND_RETURN=https://theweathermodels.com/models-v3
SESSION_COOKIE_NAME=twm_session
OAUTH_COOKIE_NAME=twm_twf_oauth
TOKEN_DB_PATH=/var/lib/twf/oauth_tokens.sqlite3
TOKEN_ENC_KEY=base64url_32bytes_key   # generated below
CORS_ORIGINS=https://theweathermodels.com