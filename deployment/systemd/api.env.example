TWF_V3_DATA_ROOT=/opt/twf_v3/data/v3
TWF_V3_LOOP_URL_PREFIX=/loop/v3
TWF_V3_WORKERS=4
TWF_V3_SCHEDULER_VARS=tmp2m,tmp850,precip_total,snowfall_total,wspd10m,refc,radar_ptype
TWF_V3_SCHEDULER_PRIMARY_VARS=tmp2m
TWF_V3_SCHEDULER_POLL_SECONDS=300
TWF_V3_SCHEDULER_KEEP_RUNS=2
TWF_V3_SCHEDULER_PROBE_VAR=tmp2m

# Loop WebP pre-generation (post-publish)
TWF_V3_LOOP_PREGENERATE_ENABLED=1
TWF_V3_LOOP_CACHE_ROOT=/opt/twf_v3/data/v3/loop_cache
TWF_V3_LOOP_PREGENERATE_WORKERS=4
TWF_V3_LOOP_WEBP_QUALITY=82
TWF_V3_LOOP_WEBP_MAX_DIM=1600
TWF_V3_LOOP_WEBP_TIER1_MAX_DIM=2400
TWF_V3_LOOP_WEBP_TIER1_QUALITY=86

# Herbie subset fetch controls (still subset-only, no full-file fallback)
TWF_HERBIE_PRIORITY=aws,nomads,google,azure,pando,pando2
TWF_HERBIE_SUBSET_RETRIES=2
TWF_HERBIE_RETRY_SLEEP_SECONDS=0.6
HERBIE_SAVE_DIR=/opt/twf_v3/herbie_cache

# TWF OAuth and REST API settings
TWF_BASE=https://theweatherforums.com
TWF_CLIENT_ID=<client id here>>
TWF_CLIENT_SECRET=<secret here>
TWF_REDIRECT_URI=https://api.theweathermodels.com/auth/twf/callback
TWF_FORUMS_ENDPOINT=https://theweatherforums.com/api/index.php?/forums/forums
TWF_TOPICS_ENDPOINT=https://theweatherforums.com/api/index.php?/forums/topics
TWF_SCOPES="profile forums_posts"
FRONTEND_RETURN=https://theweathermodels.com/models-v3
SESSION_COOKIE_NAME=twm_session
OAUTH_COOKIE_NAME=twm_twf_oauth
TOKEN_DB_PATH=/var/lib/twf/oauth_tokens.sqlite3
TOKEN_ENC_KEY=<enc key here>
TWF_API_KEY=<api key here>
CORS_ORIGINS=https://theweathermodels.com